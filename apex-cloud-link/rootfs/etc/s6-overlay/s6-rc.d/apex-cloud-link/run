#!/usr/bin/with-contenv bashio

# Parse add-on options
CONFIG_PATH=/data/options.json
SUBDOMAIN=$(bashio::config 'subdomain')
ACCESS_TOKEN=$(bashio::config 'access_token')

# Clean the subdomain if the user accidentally pasted the full domain
SUBDOMAIN=${SUBDOMAIN//.cloud.apexinfosys.in/}

# Basic validation
if [ -z "$SUBDOMAIN" ] || [ -z "$ACCESS_TOKEN" ]; then
    bashio::log.error "Subdomain or Access Token is missing!"
    bashio::log.error "Please register at portal.cloud.apexinfosys.in and configure the Add-on."
    sleep infinity
fi

echo "[ApexOS] Initializing Cloud Link for: ${SUBDOMAIN}.cloud.apexinfosys.in"

# 1. Determine Architecture to download the correct FRP Client
ARCH=$(bashio::info.arch)
FRP_VERSION="0.56.0"
FRP_ARCH=""

case $ARCH in
    aarch64) FRP_ARCH="arm64" ;;
    amd64) FRP_ARCH="amd64" ;;
    armhf|armv7) FRP_ARCH="arm" ;;
    i386) FRP_ARCH="386" ;;
    *) 
        bashio::log.error "Unsupported architecture: $ARCH"
        sleep infinity
        ;;
esac

# 2. Download FRPC if it doesn't exist or version mismatches (cached in /data so it survives restarts)
FRP_DIR="/data/frp"
FRPC_BIN="${FRP_DIR}/frpc"

if [ -f "$FRPC_BIN" ]; then
    CURRENT_VERSION=$("$FRPC_BIN" -v 2>/dev/null || echo "0")
    if [ "$CURRENT_VERSION" != "$FRP_VERSION" ]; then
        echo "[ApexOS] FRP version mismatch ($CURRENT_VERSION vs $FRP_VERSION), downloading update..."
        rm -f "$FRPC_BIN"
    fi
fi

if [ ! -f "$FRPC_BIN" ]; then
    echo "[ApexOS] Downloading FRP Client for ${FRP_ARCH}..."
    mkdir -p $FRP_DIR
    
    # Download and extract just the client binary
    wget -qO /tmp/frp.tar.gz "https://github.com/fatedier/frp/releases/download/v${FRP_VERSION}/frp_${FRP_VERSION}_linux_${FRP_ARCH}.tar.gz"
    tar -xzf /tmp/frp.tar.gz -C /tmp/
    mv "/tmp/frp_${FRP_VERSION}_linux_${FRP_ARCH}/frpc" "$FRPC_BIN"
    chmod +x "$FRPC_BIN"
    
    # Cleanup
    rm -rf /tmp/frp*
    echo "[ApexOS] Download complete."
fi

# 3. Generate the dynamic FRPC Configuration
FRPC_CONFIG="/tmp/frpc.toml"

cat << TOML_EOF > ${FRPC_CONFIG}
# Master connection to your VPS
serverAddr = "cloud.apexinfosys.in"
serverPort = 7000

# Tell FRP to retry connecting indefinitely if it drops
loginFailExit = false

# Shared FRP auth token to satisfy FRPS login verification
auth.method = "token"
auth.token = "apexcloud_transport_v1"

# Pass the user access token as metadata so the webhook can read it
[metadatas]
token = "${ACCESS_TOKEN}"

# Define the local ApexOS proxy rule
[[proxies]]
name = "ha_web_${SUBDOMAIN}"
type = "http"
localIP = "127.0.0.1"   # Match the legacy SSH add-on target on host network
localPort = 1702
customDomains = ["${SUBDOMAIN}.cloud.apexinfosys.in"]
TOML_EOF

echo "[ApexOS] Configuration generated. Connecting to cloud..."

# 4. Start the FRP Client
exec "$FRPC_BIN" -c "$FRPC_CONFIG"
