#!/command/with-contenv bashio
# ==============================================================================
# ApexOS Add-on: Spotify Connect
# Take down the S6 supervision tree when librespot fails
# ==============================================================================
if [[ "${1}" -ne 0 ]] && [[ "${1}" -ne 256 ]]; then
  bashio::log.warning "librespot crashed, halting app"
  /run/s6/basedir/bin/halt
fi

bashio::log.info "librespot stopped."
